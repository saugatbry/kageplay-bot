<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KagePlay Bot - Environment Variables</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121212; color: #e0e0e0; }
        .sidebar { background-color: #1e1e1e; height: 100vh; padding: 20px; }
        .sidebar a { color: white; text-decoration: none; display: block; padding: 10px; border-radius: 5px; margin-bottom: 10px; }
        .sidebar a:hover { background-color: #333; }
        .content { padding: 30px; }
        .card { background-color: #1e1e1e; border: none; margin-bottom: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.3); }
        .form-control { background-color: #2b2b2b; color: white; border: 1px solid #444; font-family: monospace; }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar" style="width: 250px;">
            <h4>KagePlay Bot</h4>
            <hr>
            <a href="/">⚙️ Settings</a>
            <a href="/announce">📢 Announcements</a>
            <a href="/env" style="background-color: #0d6efd;">🔒 Env Variables</a>
            <a href="/logout" class="text-danger">🚪 Logout</a>
        </div>
        
        <div class="content flex-grow-1">
            <h2>Environment Variables (.env)</h2>
            <p class="text-muted">Paste your .env file contents below to save it directly to the server. <strong>Warning: Never share your Discord Token!</strong></p>
            
            <% if (success) { %>
                <div class="alert alert-success">
                    <%= success %>
                </div>
            <% } %>

            <div class="card p-4 mt-4">
                <form action="/env" method="POST">
                    <div class="mb-3">
                        <textarea name="envContent" class="form-control" rows="15" spellcheck="false"><%= envContent %></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary mt-3 px-4">Save .env File</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
