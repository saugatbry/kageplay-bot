<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KagePlay Bot — Environment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #0d1117; color: #c9d1d9; display: flex; min-height: 100vh; margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .sidebar { width: 260px; background: #161b22; border-right: 1px solid #30363d; padding: 24px 0; display: flex; flex-direction: column; flex-shrink: 0; }
        .sidebar-brand { padding: 0 24px 24px; border-bottom: 1px solid #30363d; margin-bottom: 16px; }
        .sidebar-brand h4 { color: #f0f6fc; font-weight: 700; font-size: 1.25rem; margin: 0; }
        .sidebar a { display: flex; align-items: center; gap: 12px; padding: 10px 24px; color: #8b949e; text-decoration: none; font-size: 0.9rem; transition: all 0.15s; border-left: 3px solid transparent; }
        .sidebar a:hover, .sidebar a.active { background: #1c2128; color: #f0f6fc; border-left-color: #f0883e; }
        .sidebar a i { font-size: 1.1rem; width: 20px; text-align: center; }
        .sidebar .logout { margin-top: auto; border-top: 1px solid #30363d; padding-top: 12px; color: #f85149; }
        .main { flex: 1; padding: 32px; max-width: 800px; }
        .main h2 { font-weight: 600; font-size: 1.5rem; margin-bottom: 8px; color: #f0f6fc; }
        .main p.text-muted { color: #8b949e !important; font-size: 0.9rem; margin-bottom: 24px; }
        .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 24px; }
        .form-label { font-size: 0.85rem; color: #8b949e; margin-bottom: 4px; font-weight: 500; }
        .form-control { background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; font-size: 0.85rem; border-radius: 6px; padding: 8px 12px; font-family: 'Consolas', 'Monaco', monospace; }
        .form-control:focus { border-color: #f0883e; box-shadow: 0 0 0 2px rgba(240,136,62,0.2); color: #c9d1d9; background: #0d1117; }
        .btn-save { background: #f0883e; border: none; color: #fff; padding: 10px 32px; font-weight: 600; border-radius: 6px; transition: background 0.15s; }
        .btn-save:hover { background: #da6f2a; color: #fff; }
        .alert-success { background: #1c3d1f; border: 1px solid #2ea043; color: #7ee787; border-radius: 6px; padding: 12px 16px; font-size: 0.9rem; margin-bottom: 20px; }
        @media (max-width: 768px) {
            body { flex-direction: column; }
            .sidebar { width: 100%; border-right: none; border-bottom: 1px solid #30363d; padding: 12px 0; }
            .sidebar a { padding: 8px 16px; }
            .main { padding: 16px; }
        }
    </style>
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-brand"><h4>KagePlay Bot</h4></div>
        <a href="/"><i class="bi bi-gear-fill"></i> Settings</a>
        <a href="/announce"><i class="bi bi-megaphone-fill"></i> Announcements</a>
        <a href="/env" class="active"><i class="bi bi-key-fill"></i> Environment</a>
        <a href="/logout" class="logout"><i class="bi bi-box-arrow-left"></i> Logout</a>
    </nav>

    <div class="main">
        <h2><i class="bi bi-key-fill" style="color:#f0883e"></i> Environment Variables</h2>
        <p class="text-muted">Edit your <code>.env</code> file directly. <strong>Restart the bot</strong> after saving to apply changes.</p>

        <% if (success) { %>
            <div class="alert-success"><i class="bi bi-check-circle-fill"></i> <%= success %></div>
        <% } %>

        <div class="card">
            <form action="/env" method="POST">
                <div class="mb-3">
                    <textarea name="envContent" class="form-control" rows="15" spellcheck="false"><%= envContent %></textarea>
                </div>
                <button type="submit" class="btn-save"><i class="bi bi-floppy-fill"></i> Save .env File</button>
            </form>
        </div>
    </div>
</body>
</html>
