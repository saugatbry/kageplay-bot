<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KagePlay Bot — Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0d1117; color: #c9d1d9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; }
        .wrapper { display: flex; min-height: 100vh; }
        .sidebar { width: 260px; background: #161b22; border-right: 1px solid #30363d; padding: 24px 0; display: flex; flex-direction: column; flex-shrink: 0; }
        .sidebar-brand { padding: 0 24px 24px; border-bottom: 1px solid #30363d; margin-bottom: 16px; }
        .sidebar-brand h4 { color: #f0f6fc; font-weight: 700; font-size: 1.25rem; margin: 0; }
        .sidebar-brand small { color: #8b949e; font-size: 0.75rem; }
        .sidebar a { display: flex; align-items: center; gap: 12px; padding: 10px 24px; color: #8b949e; text-decoration: none; font-size: 0.9rem; transition: all 0.15s; border-left: 3px solid transparent; }
        .sidebar a:hover, .sidebar a.active { background: #1c2128; color: #f0f6fc; border-left-color: #f0883e; }
        .sidebar a i { font-size: 1.1rem; width: 20px; text-align: center; }
        .sidebar .logout { margin-top: auto; border-top: 1px solid #30363d; padding-top: 12px; color: #f85149; }
        .sidebar .logout:hover { color: #ff6b6b; }
        .main { flex: 1; padding: 32px; max-width: 1000px; }
        .main h2 { font-weight: 600; font-size: 1.5rem; margin-bottom: 24px; color: #f0f6fc; }
        .stat-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 28px; }
        .stat-card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 20px; text-align: center; }
        .stat-card .num { font-size: 2rem; font-weight: 700; color: #f0f6fc; }
        .stat-card .label { font-size: 0.8rem; color: #8b949e; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
        .stat-card .icon { font-size: 1.5rem; margin-bottom: 8px; }
        .stat-card.online .num { color: #3fb950; }
        .stat-card.offline .num { color: #f85149; }
        .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 24px; margin-bottom: 24px; }
        .card h5 { font-size: 1rem; font-weight: 600; color: #f0f6fc; margin-bottom: 12px; }
        .card hr { border-color: #30363d; margin: 20px 0; }
        .form-label { font-size: 0.85rem; color: #8b949e; margin-bottom: 4px; font-weight: 500; }
        .form-control { background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; font-size: 0.9rem; border-radius: 6px; padding: 8px 12px; }
        .form-control:focus { border-color: #f0883e; box-shadow: 0 0 0 2px rgba(240,136,62,0.2); color: #c9d1d9; background: #0d1117; }
        .form-control::placeholder { color: #484f58; }
        select.form-control { cursor: pointer; }
        .btn-save { background: #f0883e; border: none; color: #fff; padding: 10px 32px; font-weight: 600; border-radius: 6px; transition: background 0.15s; }
        .btn-save:hover { background: #da6f2a; color: #fff; }
        .alert-success { background: #1c3d1f; border: 1px solid #2ea043; color: #7ee787; border-radius: 6px; padding: 12px 16px; font-size: 0.9rem; margin-bottom: 20px; }
        @media (max-width: 768px) {
            .wrapper { flex-direction: column; }
            .sidebar { width: 100%; border-right: none; border-bottom: 1px solid #30363d; padding: 12px 0; }
            .sidebar a { padding: 8px 16px; }
            .main { padding: 16px; }
            .stat-cards { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>
<div class="wrapper">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <h4>KagePlay Bot</h4>
            <small>v2.0 — Admin Panel</small>
        </div>
        <a href="/" class="active"><i class="bi bi-gear-fill"></i> Settings</a>
        <a href="/announce"><i class="bi bi-megaphone-fill"></i> Announcements</a>
        <a href="/env"><i class="bi bi-key-fill"></i> Environment</a>
        <a href="/logout" class="logout"><i class="bi bi-box-arrow-left"></i> Logout</a>
    </nav>

    <div class="main">
        <h2><i class="bi bi-gear-fill" style="color:#f0883e"></i> Bot Settings</h2>

        <% if (success) { %>
            <div class="alert-success"><i class="bi bi-check-circle-fill"></i> Settings saved successfully!</div>
        <% } %>

        <div class="stat-cards">
            <div class="stat-card <%= botStatus === 'Online' ? 'online' : 'offline' %>">
                <div class="icon"><i class="bi bi-broadcast"></i></div>
                <div class="num"><%= botStatus %></div>
                <div class="label">Bot Status</div>
            </div>
            <div class="stat-card">
                <div class="icon"><i class="bi bi-server"></i></div>
                <div class="num"><%= stats.guilds %></div>
                <div class="label">Servers</div>
            </div>
            <div class="stat-card">
                <div class="icon"><i class="bi bi-people-fill"></i></div>
                <div class="num"><%= stats.users %></div>
                <div class="label">Users</div>
            </div>
            <div class="stat-card">
                <div class="icon"><i class="bi bi-chat-fill"></i></div>
                <div class="num"><%= stats.channels %></div>
                <div class="label">Channels</div>
            </div>
            <div class="stat-card">
                <div class="icon"><i class="bi bi-clock-fill"></i></div>
                <div class="num"><%= stats.uptime %>m</div>
                <div class="label">Uptime</div>
            </div>
        </div>

        <div class="card">
            <form action="/settings" method="POST">
                <h5><i class="bi bi-hand-wave-fill" style="color:#3fb950"></i> Welcome & Leave System</h5>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Welcome Channel ID</label>
                        <input type="text" name="welcomeChannel" class="form-control" value="<%= config.welcomeChannel %>" placeholder="Channel ID">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Welcome Message</label>
                        <input type="text" name="welcomeMessage" class="form-control" value="<%= config.welcomeMessage %>" placeholder="Welcome {user}!">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Welcome GIF Reaction</label>
                        <select name="welcomeReaction" class="form-control">
                            <% const reactions = ["airkiss","angrystare","bite","bleh","blush","brofist","celebrate","cheers","clap","confused","cool","cry","cuddle","dance","drool","evillaugh","facepalm","handhold","happy","headbang","hug","huh","kiss","laugh","lick","love","mad","nervous","no","nom","nosebleed","nuzzle","nyah","pat","peek","pinch","poke","pout","punch","roll","run","sad","scared","shout","shrug","shy","sigh","sing","sip","slap","sleep","slowclap","smack","smile","smug","sneeze","sorry","stare","stop","surprised","sweat","thumbsup","tickle","tired","wave","wink","woah","yawn","yay","yes"]; %>
                            <% reactions.forEach(r => { %>
                                <option value="<%= r %>" <%= config.welcomeReaction === r ? 'selected' : '' %>><%= r %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Leave Channel ID</label>
                        <input type="text" name="leaveChannel" class="form-control" value="<%= config.leaveChannel %>" placeholder="Channel ID">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Leave Message</label>
                        <input type="text" name="leaveMessage" class="form-control" value="<%= config.leaveMessage %>" placeholder="Goodbye {user}.">
                    </div>
                </div>

                <hr>

                <h5><i class="bi bi-ticket-perforated-fill" style="color:#a371f7"></i> Support Tickets</h5>
                <div class="mb-3">
                    <label class="form-label">Ticket Category ID</label>
                    <input type="text" name="ticketCategory" class="form-control" value="<%= config.ticketCategory %>" placeholder="Category ID where ticket channels are created">
                </div>

                <hr>

                <h5><i class="bi bi-broadcast" style="color:#f0883e"></i> Anime Auto-Announcements</h5>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Announcement Channel ID</label>
                        <input type="text" name="announcementChannel" class="form-control" value="<%= config.announcementChannel %>" placeholder="Channel ID">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Ping Role ID (Optional)</label>
                        <input type="text" name="pingRole" class="form-control" value="<%= config.pingRole %>" placeholder="Role ID">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Search Channel ID</label>
                        <input type="text" name="searchChannel" class="form-control" value="<%= config.searchChannel %>" placeholder="Channel ID for anime search">
                    </div>
                </div>

                <hr>

                <h5><i class="bi bi-shield-lock-fill" style="color:#f85149"></i> Security</h5>
                <div class="mb-3">
                    <label class="form-label">Dashboard Admin Password</label>
                    <input type="text" name="adminPassword" class="form-control" value="<%= config.adminPassword %>">
                </div>

                <button type="submit" class="btn-save"><i class="bi bi-floppy-fill"></i> Save Settings</button>
            </form>
        </div>
    </div>
</div>
</body>
</html>
