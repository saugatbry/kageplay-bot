<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KagePlay Bot — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #0d1117; color: #c9d1d9; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .login-card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 40px 32px 32px; width: 380px; }
        .login-card h3 { color: #f0f6fc; font-weight: 700; text-align: center; margin-bottom: 4px; }
        .login-card .subtitle { color: #8b949e; font-size: 0.85rem; text-align: center; margin-bottom: 28px; }
        .form-control { background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; border-radius: 6px; padding: 10px 14px; }
        .form-control:focus { border-color: #f0883e; box-shadow: 0 0 0 2px rgba(240,136,62,0.2); color: #c9d1d9; background: #0d1117; }
        .btn-login { background: #f0883e; border: none; color: #fff; padding: 10px; font-weight: 600; border-radius: 6px; width: 100%; transition: background 0.15s; }
        .btn-login:hover { background: #da6f2a; color: #fff; }
        .alert { background: #3d1c1c; border: 1px solid #f85149; color: #ff6b6b; border-radius: 6px; font-size: 0.9rem; padding: 10px 14px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="login-card">
        <h3>🔐 KagePlay</h3>
        <p class="subtitle">Bot Admin Dashboard</p>
        <% if (error) { %>
            <div class="alert"><%= error %></div>
        <% } %>
        <form action="/login" method="POST">
            <div class="mb-4">
                <label class="form-label" style="font-size:0.85rem;color:#8b949e;margin-bottom:6px;">Admin Password</label>
                <input type="password" name="password" class="form-control" placeholder="Enter password" required>
            </div>
            <button type="submit" class="btn-login">Login</button>
        </form>
    </div>
</body>
</html>
